{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)\\.php",
      "destination": "/api/index.php"
    },
    {
      "source": "/(wp-admin|wp-includes|wp-content)/(.*)",
      "destination": "/$1/$2"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.php"
    }
  ]
}
